@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(OpenCV 4.0 REQUIRED)
find_dependency(Qt6 6.8 REQUIRED COMPONENTS Core Qml Concurrent)

# Include target configuration
include("${CMAKE_CURRENT_LIST_DIR}/qlucidcameraTargets.cmake")

if(TARGET qlucidcamera AND NOT TARGET qlucidcamera::qlucidcamera)
  add_library(qlucidcamera::qlucidcamera ALIAS qlucidcamera)
endif()

check_required_components(qlucidcamera)